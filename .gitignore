# Swift Package Manager
.build/
.swiftpm/
# Only the (dependency-less) root package's resolved file; the app's
# Package.resolved (under Engram.xcodeproj) is committed to pin dep versions.
/Package.resolved

# Xcode
*.xcodeproj/project.pbxproj.bak
xcuserdata/
DerivedData/
*.xcuserstate
build/

# macOS
.DS_Store

# Databases — never commit memory stores
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Local work loop (/work, /queue) — local-only, not shared
remaining-tasks.md
transcripts/

# Migration scratch (mcp-memory-service → Engram); regenerate via scripts/
memory-dump.md
memory-relevant.md
memory-slop.md
/tmp/mem_catalog.txt

# Icon-design scratch renders (Nano Banana ideation output)
docs/design/renders/

# Regenerable eval plot artifacts — the per-run records under eval/runs/ ARE
# committed (comparable history); these are scratch from `--dump-scores` + the
# ROC plotter (scripts/plot_threshold.py).
eval/scores-*.json
eval/thresholds-*.json
eval/threshold.png

# LLVM profiling output
*.profraw
